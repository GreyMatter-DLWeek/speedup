PORT=3000

# OpenAI API
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4.1-mini
# Optional (keep default unless using a compatible proxy)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Azure AI Search
# AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
# AZURE_SEARCH_API_KEY=<your-search-admin-or-query-key>
# AZURE_SEARCH_INDEX_NAME=speedup-notes-index
# AZURE_SEARCH_ID_FIELD=id
# AZURE_SEARCH_TITLE_FIELD=title
# AZURE_SEARCH_CONTENT_FIELD=content
# AZURE_SEARCH_SOURCE_FIELD=source

# Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=<your-storage-connection-string>
# AZURE_STORAGE_CONTAINER=speedup-students
