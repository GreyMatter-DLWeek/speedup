PORT=3000
NODE_ENV=development

# CORS: include local frontend and your GitHub Pages domain.
ALLOWED_ORIGINS=http://localhost:3000,https://greymatter-dlweek.github.io

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Optional allowlist for Study Hub model dropdown (comma-separated)
OPENAI_ALLOWED_MODELS=gpt-4.1-mini,gpt-4o-mini
# Optional PDFBox jar override (defaults to ./pdfbox-app-3.0.6.jar if present)
PDFBOX_JAR_PATH=

# Firebase Admin (choose ONE mode)
# Mode A (recommended): full service account JSON on one line
FIREBASE_SERVICE_ACCOUNT_JSON=<json-string-from-firebase-service-account>

# Mode B: split fields (if not using JSON above)
# FIREBASE_PROJECT_ID=<your-project-id>
# FIREBASE_CLIENT_EMAIL=<service-account-client-email>
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional bucket (for Firebase Admin initialization)
FIREBASE_STORAGE_BUCKET=<your-project-id>.appspot.com

# RAG collection
FIREBASE_RAG_COLLECTION=speedup_rag_notes

# Cloudinary (for practice paper file storage)
CLOUDINARY_CLOUD_NAME=<your-cloudinary-cloud-name>
CLOUDINARY_API_KEY=<your-cloudinary-api-key>
CLOUDINARY_API_SECRET=<your-cloudinary-api-secret>
ENABLE_FILE_STORAGE=true
